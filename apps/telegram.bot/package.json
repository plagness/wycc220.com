{
  "name": "@wycc220/telegram.bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "tsc --noEmit",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/core/*.test.ts src/modules/**/*.test.ts"
  },
  "dependencies": {
    "dotenv": "17.2.3",
    "fastify": "5.10.0"
  },
  "devDependencies": {
    "@types/node": "22.16.5",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  }
}
